# Byte-compiled / Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
wheels/

# Virtual environments
.venv/
venv/
.uv-cache/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# All data artifacts: the repository is code-only.
# PBF inputs, intermediate outputs, Arrow/Parquet files, saved datasets,
# Hugging Face caches, etc. all live on the configured external data root.
data/
*.arrow
*.parquet
*.pbf
*.osm.pbf
.huggingface/
**/__pycache__/

# Tests ship a small set of synthetic parquet fixtures used to assert
# the documented schemas. The exception below carves out exactly the
# committed fixture location so users cannot accidentally push
# real data into the repository.
!tests/fixtures/**/*.parquet

# Editor / OS noise
.DS_Store
.idea/
.vscode/
